---
const testimonios = [
  {
    title: 'Testimonio 1',
    src: '/testimonios/TESTIMONIO-1.mp4',
  },
];
---

<section class="py-24 bg-gradient-to-br from-colegio-blue via-colegio-blue/95 to-colegio-blue text-white relative overflow-hidden">
  <div class="absolute top-0 left-0 w-96 h-96 bg-colegio-blue/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>

  <div class="max-w-5xl mx-auto px-4 relative z-10">
    <div class="text-center mb-16 fade-in-section">
      <span class="text-colegio-yellow font-bold text-sm tracking-wider uppercase mb-2 block">Experiencias Reales</span>
      <h2 class="text-4xl md:text-5xl font-black mb-4">Testimonios de Nuestra Comunidad</h2>
      <div class="w-24 h-1.5 bg-gradient-to-r from-transparent via-colegio-yellow to-transparent mx-auto"></div>
      <p class="mt-6 text-white/90 text-base md:text-lg max-w-2xl mx-auto">
        Conoce las experiencias de familias que forman parte de nuestra comunidad educativa.
      </p>
    </div>

    <div class="relative max-w-[90rem] mx-auto">
      {testimonios.map((testimonio) => (
        <>
          <div class="hidden md:block px-4">
            <div class="grid grid-cols-3 gap-6">
              <div class="col-start-2 bg-white/10 backdrop-blur-sm rounded-2xl overflow-hidden shadow-2xl border border-white/20">
                <div class="relative h-[280px] sm:h-[360px] md:h-[450px]">
                  <video
                    class="testimonio-video absolute top-0 left-0 w-full h-full object-cover"
                    controls
                    playsinline
                    preload="metadata"
                    title={testimonio.title}
                    src={testimonio.src}
                  ></video>
                </div>
              </div>
            </div>
          </div>

          <div class="md:hidden px-4">
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl overflow-hidden shadow-2xl border border-white/20">
              <div class="relative h-[350px]">
                <video
                  class="testimonio-video absolute top-0 left-0 w-full h-full object-cover"
                  controls
                  playsinline
                  preload="metadata"
                  title={testimonio.title}
                  src={testimonio.src}
                ></video>
              </div>
            </div>
          </div>
        </>
      ))}
      <div class="text-center mt-6 text-sm text-white/70">
        Próximamente agregaremos más testimonios.
      </div>
    </div>
  </div>
</section>

<style>
  .testimonio-video:fullscreen,
  .testimonio-video:-webkit-full-screen {
    object-fit: contain;
    background: #000;
  }
</style>

