---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import StatsSection from '../components/home/StatsSection.astro';
import BienvenidosSection from '../components/home/BienvenidosSection.astro';
import UniversidadesSection from '../components/home/UniversidadesSection.astro';
import EstandaresSection from '../components/home/EstandaresSection.astro';
import TestimoniosSection from '../components/home/TestimoniosSection.astro';
import GaleriaSection from '../components/home/GaleriaSection.astro';

const heroSlides = [
  {
    title: 'Educación que <span class="text-transparent bg-clip-text bg-gradient-to-r from-colegio-yellow via-yellow-300 to-amber-400">Inspira</span> el Futuro',
    subtitle: '✨ Ciclo Escolar 2026 - Inscripciones Abiertas',
    description: 'Formamos líderes con valores, excelencia académica y visión global para transformar el mundo.',
    video: '/video-carrusel2.mp4',
    duration: 10000,
    cta: { text: 'Proceso de Admisión', link: '/admisiones' }
  },
  {
    title: 'Educación que <span class="text-transparent bg-clip-text bg-gradient-to-r from-colegio-yellow via-yellow-300 to-amber-400">Inspira</span> el Futuro',
    subtitle: '✨ Ciclo Escolar 2026 - Inscripciones Abiertas',
    description: 'Formamos líderes con valores, excelencia académica y visión global para transformar el mundo.',
    image: '/portada.jpeg',
    duration: 5000,
    cta: { text: 'Proceso de Admisión', link: '/admisiones' }
  },
  {
    title: 'Excelencia <span class="text-transparent bg-clip-text bg-gradient-to-r from-colegio-yellow via-yellow-300 to-amber-400">Académica</span> Comprobada',
    subtitle: '🏆 25 Años de Trayectoria',
    description: '98% de nuestros egresados ingresan a las mejores universidades del país.',
    image: '/portada.jpeg',
    duration: 5000,
    cta: { text: 'Conoce Nuestros Logros', link: '/nosotros' }
  },
  {
    title: 'Formación <span class="text-transparent bg-clip-text bg-gradient-to-r from-colegio-yellow via-yellow-300 to-amber-400">Bilingüe</span> y Tecnológica',
    subtitle: '🌎 Visión Global',
    description: 'Preparamos estudiantes competitivos con dominio del inglés y habilidades digitales del siglo XXI.',
    image: '/portada.jpeg',
    duration: 5000,
    cta: { text: 'Descubre Nuestro Modelo', link: '/modelo-educativo' }
  },
  {
    title: 'Instalaciones de <span class="text-transparent bg-clip-text bg-gradient-to-r from-colegio-yellow via-yellow-300 to-amber-400">Primera Clase</span>',
    subtitle: '🏫 Espacios Modernos',
    description: 'Laboratorios, canchas deportivas, biblioteca digital y aulas equipadas con tecnología de punta.',
    image: '/portada.jpeg',
    duration: 5000,
    cta: { text: 'Conoce el Campus', link: '/instalaciones' }
  }
];
---

<Layout
  title="Bienvenidos | BRÜNING SCHOOL"
  description="Brüning School – Colegio privado de excelencia en Trujillo. Educación Primaria y Secundaria con certificaciones Cambridge, IBEC y formación bilingüe. ¡Inscripciones 2026 abiertas!"
  ogImage="/portada.webp"
>
  <HeroCarousel slides={heroSlides} autoplayInterval={5000} />
  <StatsSection />
  <BienvenidosSection />
  <UniversidadesSection />
  <EstandaresSection />
  <TestimoniosSection />
  <GaleriaSection />
</Layout>
