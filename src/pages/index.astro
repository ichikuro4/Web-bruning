---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import StatsSection from '../components/home/StatsSection.astro';
import BienvenidosSection from '../components/home/BienvenidosSection.astro';
import UniversidadesSection from '../components/home/UniversidadesSection.astro';
import EstandaresSection from '../components/home/EstandaresSection.astro';
import TestimoniosSection from '../components/home/TestimoniosSection.astro';
import GaleriaSection from '../components/home/GaleriaSection.astro';

const heroSlides = [
  {
    title: 'Educación que <span class="text-transparent bg-clip-text bg-gradient-to-r from-colegio-yellow via-yellow-300 to-amber-400">Inspira</span> el Futuro',
    subtitle: '✨ Ciclo Escolar 2026 - Inscripciones Abiertas',
    description: 'Formamos líderes con valores, excelencia académica y visión global para transformar el mundo.',
    video: '/video-carrusel2.mp4',
    duration: 10000,
    cta: { text: 'Proceso de Admisión', link: '/admisiones' }
  },
  {
    title: 'Educación que <span class="text-transparent bg-clip-text bg-gradient-to-r from-colegio-yellow via-yellow-300 to-amber-400">Inspira</span> el Futuro',
    subtitle: '✨ Ciclo Escolar 2026 - Inscripciones Abiertas',
    description: 'Formamos líderes con valores, excelencia académica y visión global para transformar el mundo.',
    image: '/portada.jpeg',
    duration: 5000,
    cta: { text: 'Proceso de Admisión', link: '/admisiones' }
  },
  {
    title: 'Aprendizaje con <span class="text-transparent bg-clip-text bg-gradient-to-r from-colegio-yellow via-yellow-300 to-amber-400">Valores</span> y Acompañamiento Cercano',
    subtitle: '🤝 Formación integral en cada etapa escolar',
    description: 'Potenciamos las habilidades académicas, sociales y emocionales de nuestros estudiantes con una educación humana y exigente.',
    image: '/portada2.jpeg',
    contentAlign: 'right' as const,
    duration: 5000,
    cta: { text: 'Conoce Nuestra Propuesta', link: '/nosotros/filosofia' }
  },
  {
    title: 'Niveles <span class="text-transparent bg-clip-text bg-gradient-to-r from-colegio-yellow via-yellow-300 to-amber-400">Educativos</span> para Crecer con Seguridad',
    subtitle: '🎓 Primaria y Secundaria',
    description: 'Acompañamos el desarrollo de tus hijos en cada etapa con un plan académico sólido y atención personalizada.',
    image: '/portada3.jpeg',
    duration: 5000,
    ctas: [
      { text: 'Primaria', link: '/niveles/primaria' },
      { text: 'Secundaria', link: '/niveles/secundaria' }
    ]
  }
];
---

<Layout
  title="Bienvenidos | BRÜNING SCHOOL"
  description="Brüning School – Colegio privado de excelencia en Trujillo. Educación Primaria y Secundaria con certificaciones Cambridge, IBEC y formación bilingüe. ¡Inscripciones 2026 abiertas!"
  ogImage="/portada.webp"
>
  <HeroCarousel slides={heroSlides} autoplayInterval={5000} />
  <StatsSection />
  <BienvenidosSection />
  <UniversidadesSection />
  <EstandaresSection />
  <TestimoniosSection />
  <GaleriaSection />
</Layout>
