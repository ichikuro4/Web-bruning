---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Talleres | BRÜNING SCHOOL" description="Descubre los talleres artísticos y deportivos de Brüning School. Música, danza, fútbol, básquet y más actividades extracurriculares para el desarrollo integral de tus hijos.">
  <main class="pt-24 md:pt-20">
    
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-colegio-blue via-colegio-blue/90 to-colegio-blue text-white py-20">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-3xl sm:text-4xl md:text-6xl font-extrabold mb-6">
          Nuestros <span class="text-colegio-yellow">Talleres</span>
        </h1>
        <p class="text-base sm:text-lg md:text-2xl text-white/90 max-w-3xl mx-auto">
          Espacios de formación integral que complementan la excelencia académica y potencian las habilidades de nuestros estudiantes
        </p>
      </div>
    </section>

    <!-- Filtros de categoría -->
    <section class="py-10 bg-white sticky top-[80px] md:top-[88px] lg:top-[96px] z-40 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 flex flex-wrap justify-center gap-3">
        <button class="talleres-btn active bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="academicos">📚 Académicos</button>
        <button class="talleres-btn bg-white border-2 border-colegio-blue/20 hover:bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="artisticos">🎨 Artísticos</button>
        <button class="talleres-btn bg-white border-2 border-colegio-blue/20 hover:bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="deportivos">🏆 Deportivos</button>
      </div>
    </section>

    <!-- ── ACADÉMICOS ── -->
    <section data-talleres-section="academicos" class="py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Talleres Académicos</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto mb-6"></div>
          <p class="text-base md:text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Espacios de enriquecimiento intelectual que refuerzan y amplían las competencias académicas de nuestros estudiantes, preparándolos para los más altos estándares educativos.
          </p>
        </div>
        <div class="space-y-24">

          <!-- Francés -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/talleres/frances.jpg" alt="Taller de Francés"
                  class="w-full h-[260px] sm:h-[320px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1502602898657-3e91760cbb34?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">ACADÉMICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">Francés</h3>
              <p class="text-gray-700 text-base leading-relaxed">
                Formación en el idioma francés que amplía el horizonte cultural e internacional de nuestros estudiantes, abriendo puertas a oportunidades académicas y profesionales en el mundo francófono. El alumno adquiere habilidades comunicativas en un tercer idioma, enriquecimiento intercultural y una ventaja competitiva para acceder a universidades internacionales.
              </p>
            </div>
          </div>

          <!-- Oratorio y Declamación -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">ACADÉMICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">Oratorio y Declamación</h3>
              <p class="text-gray-700 text-base leading-relaxed">
                Desarrollo del arte de la palabra y la expresión oral, formando oradores seguros y elocuentes. El alumno adquiere confianza para hablar en público, dominio de la expresión verbal y la oportunidad de participar en concursos de oratoria y declamación.
              </p>
            </div>
            <div>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/talleres/oratorio.jpg" alt="Taller de Oratorio y Declamación"
                  class="w-full h-[260px] sm:h-[320px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1475721027785-f74eccf877e2?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
          </div>

          <!-- Círculo de Excelencia -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/talleres/circulo-excelencia.jpg" alt="Círculo de Excelencia"
                  class="w-full h-[260px] sm:h-[320px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">ACADÉMICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">Círculo de Excelencia</h3>
              <p class="text-gray-700 text-base leading-relaxed">
                Programa de alto rendimiento académico orientado a potenciar a los estudiantes más destacados con metodologías avanzadas. El alumno adquiere preparación para olimpiadas y concursos nacionales, mentoría personalizada y un aprendizaje más profundo y acelerado.
              </p>
            </div>
          </div>

          <!-- Preparación Internacional Cambridge -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">ACADÉMICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">Preparación Internacional Cambridge</h3>
              <p class="text-gray-700 text-base leading-relaxed">
                Programa intensivo de preparación para las certificaciones Cambridge de inglés con estándares internacionales. El alumno obtiene preparación para exámenes Movers, KET y PET, acceso al convenio con la UCV y una certificación de reconocimiento mundial.
              </p>
            </div>
            <div>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/talleres/cambridge.jpg" alt="Preparación Internacional Cambridge"
                  class="w-full h-[260px] sm:h-[320px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1546410531-bb4caa6b424d?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── ARTÍSTICOS ── -->
    <section data-talleres-section="artisticos" class="hidden py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Talleres Artísticos</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto mb-6"></div>
          <p class="text-base md:text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Espacios de expresión creativa donde nuestros estudiantes descubren y desarrollan su talento artístico, cultivando la sensibilidad, la creatividad y el amor por el arte.
          </p>
        </div>
        <div class="space-y-24">

          <!-- Danza -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/talleres/danza.jpg" alt="Taller de Danza"
                  class="w-full h-[260px] sm:h-[320px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1508700929628-666bc8bd84ea?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">ARTÍSTICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">Danza</h3>
              <p class="text-gray-700 text-base leading-relaxed">
                Preservación y difusión del patrimonio cultural peruano mediante danzas tradicionales y contemporáneas. El alumno adquiere identidad cultural, coordinación motriz y la oportunidad de representar al colegio en eventos institucionales y culturales.
              </p>
            </div>
          </div>

          <!-- Música -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">ARTÍSTICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">Música</h3>
              <p class="text-gray-700 text-base leading-relaxed">
                Formación musical integral que desarrolla la sensibilidad artística y la expresión emocional mediante instrumentos, técnica vocal y teoría musical. El alumno adquiere creatividad, confianza en escena y participa en presentaciones y eventos culturales.
              </p>
            </div>
            <div>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/talleres/musica.jpg" alt="Taller de Música"
                  class="w-full h-[260px] sm:h-[320px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1507838153414-b4b713384a76?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
          </div>

          <!-- Dibujo y Pintura -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/talleres/dibujo.jpg" alt="Taller de Dibujo y Pintura"
                  class="w-full h-[260px] sm:h-[320px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1460661419201-fd4cecdf8a8b?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">ARTÍSTICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">Dibujo y Pintura</h3>
              <p class="text-gray-700 text-base leading-relaxed">
                Exploración de las artes plásticas mediante técnicas de dibujo y pintura que desarrollan la percepción visual y la creatividad. El alumno aprende acuarela, acrílico y lápiz, y tiene la oportunidad de exponer sus obras en exposiciones artísticas institucionales.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── DEPORTIVOS ── -->
    <section data-talleres-section="deportivos" class="hidden py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Talleres Deportivos</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto mb-6"></div>
          <p class="text-base md:text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Programas deportivos que forjan el carácter, la disciplina y el trabajo en equipo, promoviendo hábitos de vida saludable y el espíritu competitivo en nuestros estudiantes.
          </p>
        </div>
        <div class="space-y-24">

          <!-- Ajedrez -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/talleres/ajedrez.jpg" alt="Taller de Ajedrez"
                  class="w-full h-[260px] sm:h-[320px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1529699211952-734e80c4d42b?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">DEPORTIVO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">Ajedrez</h3>
              <p class="text-gray-700 text-base leading-relaxed">
                Estimulación del razonamiento estratégico y la concentración mediante el aprendizaje sistemático del ajedrez. El alumno adquiere pensamiento analítico, mejora de memoria y la posibilidad de competir en torneos escolares y regionales.
              </p>
            </div>
          </div>

          <!-- Vóley -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">DEPORTIVO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">Vóley</h3>
              <p class="text-gray-700 text-base leading-relaxed">
                Desarrollo de habilidades deportivas mediante la práctica sistemática del vóley, fomentando el trabajo coordinado y la comunicación. El alumno adquiere coordinación física, espíritu de equipo y accede a competencias deportivas a nivel regional.
              </p>
            </div>
            <div>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/talleres/voleibol.jpg" alt="Taller de Vóley"
                  class="w-full h-[260px] sm:h-[320px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1612872087720-bb876e2e67d1?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
          </div>

          <!-- Fútbol -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/talleres/futbol.jpg" alt="Taller de Fútbol"
                  class="w-full h-[260px] sm:h-[320px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1579952363873-27f3bade9f55?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">DEPORTIVO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">Fútbol</h3>
              <p class="text-gray-700 text-base leading-relaxed">
                Formación deportiva integral que promueve el trabajo en equipo, la disciplina y el espíritu competitivo. El alumno desarrolla habilidades técnicas y tácticas, fomenta hábitos saludables y participa en campeonatos interescolares.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Beneficios Generales -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">BENEFICIOS de Nuestros Talleres</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          
          <!-- Beneficio 1 -->
          <div class="bg-gradient-to-br from-gray-50 to-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100">
            <div class="w-16 h-16 bg-gradient-to-br from-colegio-blue to-colegio-blue/80 rounded-2xl flex items-center justify-center mb-6 mx-auto">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-colegio-blue mb-3 text-center">Desarrollo Integral</h3>
            <p class="text-gray-600 text-center leading-relaxed">
              Formación equilibrada que complementa la excelencia académica con habilidades artísticas, deportivas y tecnológicas.
            </p>
          </div>

          <!-- Beneficio 2 -->
          <div class="bg-gradient-to-br from-gray-50 to-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100">
            <div class="w-16 h-16 bg-gradient-to-br from-colegio-yellow to-yellow-500 rounded-2xl flex items-center justify-center mb-6 mx-auto">
              <svg class="w-8 h-8 text-colegio-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-colegio-blue mb-3 text-center">Valores y Disciplina</h3>
            <p class="text-gray-600 text-center leading-relaxed">
              Fortalecimiento del compromiso, la responsabilidad y el respeto mediante la práctica constante en ambientes formativos.
            </p>
          </div>

          <!-- Beneficio 3 -->
          <div class="bg-gradient-to-br from-gray-50 to-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100">
            <div class="w-16 h-16 bg-gradient-to-br from-colegio-blue to-colegio-blue/80 rounded-2xl flex items-center justify-center mb-6 mx-auto">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-colegio-blue mb-3 text-center">Descubrimiento de Talentos</h3>
            <p class="text-gray-600 text-center leading-relaxed">
              Identificación temprana de aptitudes especiales que permiten potenciar las habilidades naturales de cada estudiante.
            </p>
          </div>

        </div>
      </div>
    </section>


  </main>
</Layout>

<script>
  const botones = document.querySelectorAll('.talleres-btn');
  const secciones = document.querySelectorAll('[data-talleres-section]');
  const seccionesValidas = new Set(['academicos', 'artisticos', 'deportivos']);
  const seccionPorDefecto = 'academicos';

  function mostrarSeccion(seccion: string) {
    secciones.forEach(s => {
      const el = s as HTMLElement;
      if (el.dataset.talleresSection === seccion) {
        el.classList.remove('hidden');
        el.style.opacity = '0';
        requestAnimationFrame(() => { el.style.opacity = '1'; });
      } else {
        el.classList.add('hidden');
      }
    });
  }

  function actualizarBotonActivo(seccion: string) {
    botones.forEach(btn => {
      const boton = btn as HTMLElement;
      const esActivo = boton.dataset.seccion === seccion;
      boton.classList.toggle('active', esActivo);
      boton.classList.toggle('bg-colegio-yellow', esActivo);
      boton.classList.toggle('bg-white', !esActivo);
    });
  }

  function obtenerSeccionDesdeHash() {
    const hash = window.location.hash.replace('#', '').toLowerCase();
    return seccionesValidas.has(hash) ? hash : seccionPorDefecto;
  }

  function activarSeccion(seccion: string, actualizarHash = false) {
    mostrarSeccion(seccion);
    actualizarBotonActivo(seccion);
    if (actualizarHash) {
      history.replaceState(null, '', `#${seccion}`);
    }
  }

  botones.forEach(btn => {
    btn.addEventListener('click', () => {
      const sec = (btn as HTMLElement).dataset.seccion;
      if (sec && seccionesValidas.has(sec)) {
        activarSeccion(sec, true);
      }
    });
  });

  window.addEventListener('hashchange', () => {
    activarSeccion(obtenerSeccionDesdeHash());
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  activarSeccion(obtenerSeccionDesdeHash());
</script>

<style>
  img { transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
  [data-talleres-section] { transition: opacity 0.25s ease; }
</style>

